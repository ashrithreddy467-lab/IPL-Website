<script>
/* PAGE ROUTER */
function showPage(id){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-link').forEach(a=>a.classList.remove('active'));
  const t=document.querySelector(`.page[data-page="${id}"]`);
  if(t){t.classList.add('active');window.scrollTo({top:0,behavior:'smooth'});}
  document.querySelectorAll(`.nav-link[data-page="${id}"]`).forEach(a=>a.classList.add('active'));
  if(id==='home')startCounters();
}
document.addEventListener('click',e=>{
  const l=e.target.closest('.nav-link');
  if(l){e.preventDefault();const p=l.dataset.page;if(p)showPage(p);}
});

/* LIVE CLOCK */
function tick(){
  const n=new Date(),h=n.getHours()%12||12,m=n.getMinutes(),s=n.getSeconds(),ap=n.getHours()>=12?'PM':'AM';
  document.getElementById('liveClock').textContent=`${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')} ${ap}`;
}
setInterval(tick,1000);tick();

/* COUNTER ANIMATION */
function animateCounter(el,target,dur){
  let v=0;const step=target/(dur/16);
  const t=setInterval(()=>{v+=step;if(v>=target){el.textContent=target;clearInterval(t);return;}el.textContent=Math.floor(v);},16);
}
function startCounters(){document.querySelectorAll('[data-count]').forEach(el=>animateCounter(el,+el.dataset.count,1200));}
startCounters();

/* FAN POLL */
const pollData=[
  {abbr:'MSD',name:'M.S Dhoni',team:'CSK',votes:4820},
  {abbr:'SS',name:'Rohit Sharma',team:'Mumbai Indians',votes:4311},
  {abbr:'VK',name:'Virat Kohli',team:'RCB',votes:3975},
  {abbr:'NP',name:'Nicholas Pooran',team:'LSG',votes:2140},
  {abbr:'VS',name:'Vaibhav Suryavanshi',team:'Rajasthan Royals',votes:1887},
  {abbr:'SKY',name:'Suryakumar Yadav',team:'Mumbai Indians',votes:1430},
];
let voted=false,votes=pollData.map(p=>p.votes);
function total(){return votes.reduce((a,b)=>a+b,0);}
function render(sel){
  const tot=total(),c=document.getElementById('pollOptions');
  c.innerHTML='';
  votes.forEach((v,i)=>{
    const pct=Math.round(v/tot*100),o=document.createElement('div');
    o.className='poll-option'+(i===sel?' selected':'');
    o.innerHTML=`<div class="poll-bar" style="width:${voted?pct:0}%"></div><div class="poll-option-inner"><span class="poll-team-abbr">${pollData[i].abbr}</span><span class="poll-team-name">${pollData[i].name} <span style="font-size:.68rem;opacity:.38;">· ${pollData[i].team}</span></span>${voted?`<div><div class="poll-pct">${pct}%</div><div class="poll-count">${v.toLocaleString()} votes</div></div>`:''}</div>`;
    if(!voted)o.addEventListener('click',()=>{voted=true;votes[i]++;render(i);document.getElementById('pollNote').innerHTML=`You voted for <span>${pollData[i].name}</span> 🎉 · ${total().toLocaleString()} total votes`;});
    c.appendChild(o);
  });
}
render(-1);
</script>

