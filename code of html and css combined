<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>IPL 2025 | Official League</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@400;500;600;700;800&family=Barlow+Condensed:wght@600;700;800&display=swap" rel="stylesheet">
<style>
:root{--orange:#ff6b35;--amber:#ffb347;--glass:rgba(255,255,255,0.06);--border:rgba(255,255,255,0.12);}
*{margin:0;padding:0;box-sizing:border-box;scroll-behavior:smooth;}
body{font-family:'Barlow',sans-serif;background:linear-gradient(rgba(0,0,0,0.88),rgba(0,0,0,0.92)),url("https://i.pinimg.com/736x/ee/da/16/eeda16b77f4bce9bcd6270c75ecfee65.jpg") no-repeat center center fixed;background-size:cover;color:#fff;overflow-x:hidden;}

/* TICKER */
.ticker-wrap{background:linear-gradient(90deg,var(--orange),var(--amber),var(--orange));padding:.35rem 0;overflow:hidden;white-space:nowrap;}
.ticker-track{display:inline-block;animation:ticker 42s linear infinite;font-family:'Barlow Condensed',sans-serif;font-size:.76rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:#000;}
.ticker-track span{margin:0 2rem;}
@keyframes ticker{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* HEADER */
header{position:sticky;top:0;background:rgba(0,0,0,0.85);backdrop-filter:blur(20px);display:flex;justify-content:space-between;align-items:center;padding:.8rem 2.5rem;z-index:1000;border-bottom:1px solid rgba(255,107,53,0.2);box-shadow:0 4px 30px rgba(0,0,0,0.5);}
.logo{font-family:'Bebas Neue',sans-serif;font-size:2rem;letter-spacing:4px;background:linear-gradient(90deg,var(--orange),var(--amber));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;filter:drop-shadow(0 0 12px rgba(255,107,53,.45));}
nav{display:flex;align-items:center;gap:.15rem;flex-wrap:wrap;}
nav a{text-decoration:none;color:rgba(255,255,255,.7);padding:.4rem .8rem;font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:.78rem;letter-spacing:1.5px;text-transform:uppercase;border-radius:6px;transition:all .25s;position:relative;}
nav a::after{content:'';position:absolute;bottom:0;left:50%;right:50%;height:2px;background:linear-gradient(90deg,var(--orange),var(--amber));border-radius:2px;transition:.3s;opacity:0;}
nav a:hover{color:#fff;background:rgba(255,107,53,.1);}
nav a.active{color:var(--orange);background:rgba(255,107,53,.12);}
nav a.active::after{left:10%;right:10%;opacity:1;}
.live-badge{display:flex;align-items:center;gap:.5rem;font-family:'Barlow Condensed',sans-serif;font-size:.72rem;font-weight:700;letter-spacing:1px;color:rgba(255,255,255,.45);padding-left:1.2rem;border-left:1px solid rgba(255,255,255,.1);white-space:nowrap;}
.live-dot{width:7px;height:7px;border-radius:50%;background:#4ade80;box-shadow:0 0 6px #4ade80;animation:pulse 1.5s ease-in-out infinite;}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(1.4)}}

/* PAGE SYSTEM */
.page{display:none;}
.page.active{display:block;animation:pageIn .4s cubic-bezier(.22,.68,0,1.2);}
@keyframes pageIn{from{opacity:0;transform:translateY(16px) scale(.99)}to{opacity:1;transform:translateY(0) scale(1)}}

/* SECTION */
section{padding:4rem 2rem;max-width:1300px;margin:auto;}
.section-eyebrow{text-align:center;font-family:'Barlow Condensed',sans-serif;font-size:.68rem;letter-spacing:4px;text-transform:uppercase;color:rgba(255,179,71,.6);margin-bottom:.35rem;}
h2{text-align:center;font-family:'Bebas Neue',sans-serif;font-size:2.9rem;letter-spacing:4px;margin-bottom:.4rem;background:linear-gradient(90deg,var(--orange),var(--amber));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;filter:drop-shadow(0 0 20px rgba(255,107,53,.25));}
.section-divider{width:55px;height:3px;background:linear-gradient(90deg,var(--orange),var(--amber));border-radius:3px;margin:1rem auto 3rem;}

/* HERO */
.hero{text-align:center;padding:5rem 2rem 4rem;position:relative;}
.hero-badge{display:inline-block;font-family:'Barlow Condensed',sans-serif;font-size:.68rem;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--orange);border:1px solid rgba(255,107,53,.4);padding:.32rem 1.1rem;border-radius:20px;background:rgba(255,107,53,.08);margin-bottom:1.4rem;animation:slideDown .6s ease both;}
.hero h1{font-family:'Bebas Neue',sans-serif;font-size:clamp(3.5rem,8vw,6.5rem);letter-spacing:6px;line-height:1;background:linear-gradient(135deg,#fff 30%,var(--amber) 70%,var(--orange) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:1.2rem;filter:drop-shadow(0 0 40px rgba(255,107,53,.2));animation:slideDown .7s .1s ease both;}
.hero p{max-width:580px;margin:auto;font-size:1.02rem;line-height:1.75;color:rgba(255,255,255,.6);animation:slideDown .7s .2s ease both;}
@keyframes slideDown{from{opacity:0;transform:translateY(-16px)}to{opacity:1;transform:translateY(0)}}
.btn{display:inline-block;margin-top:2.2rem;padding:.88rem 2.8rem;border-radius:50px;background:linear-gradient(45deg,var(--orange),var(--amber));color:#000;font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1rem;letter-spacing:2px;text-transform:uppercase;text-decoration:none;transition:.35s;position:relative;overflow:hidden;box-shadow:0 4px 20px rgba(255,107,53,.35);animation:slideDown .7s .3s ease both;}
.btn::before{content:'';position:absolute;inset:0;background:linear-gradient(45deg,transparent 40%,rgba(255,255,255,.25) 50%,transparent 60%);transform:translateX(-100%);transition:.55s;}
.btn:hover{transform:scale(1.07);box-shadow:0 6px 30px rgba(255,107,53,.55);}
.btn:hover::before{transform:translateX(100%);}

/* HERO STATS */
.hero-stats{display:flex;justify-content:center;gap:2.5rem;margin-top:3.5rem;flex-wrap:wrap;animation:slideDown .7s .4s ease both;}
.hero-stat{text-align:center;}
.hero-stat-val{font-family:'Bebas Neue',sans-serif;font-size:2.8rem;letter-spacing:2px;background:linear-gradient(90deg,var(--orange),var(--amber));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1;}
.hero-stat-lbl{font-family:'Barlow Condensed',sans-serif;font-size:.62rem;letter-spacing:2.5px;text-transform:uppercase;color:rgba(255,255,255,.35);margin-top:.3rem;}
.hero-stat-sep{width:1px;background:rgba(255,255,255,.1);align-self:stretch;margin:.3rem 0;}

/* TEAMS */
.teams{display:grid;grid-template-columns:repeat(auto-fit,minmax(210px,1fr));gap:1.4rem;}
.team-link{text-decoration:none;color:inherit;}
.team-card{background:var(--glass);backdrop-filter:blur(15px);border-radius:18px;padding:1.8rem 1.4rem;text-align:center;transition:all .4s cubic-bezier(.22,.68,0,1.2);border:1px solid var(--border);position:relative;overflow:hidden;}
.team-card::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,107,53,.08) 0%,transparent 60%);opacity:0;transition:.4s;}
.team-card:hover::before{opacity:1;}
.team-card:hover{transform:translateY(-12px) scale(1.03);box-shadow:0 20px 50px rgba(0,0,0,.7),0 0 30px rgba(255,107,53,.12);border-color:rgba(255,107,53,.35);}
.team-card img{width:78px;height:78px;border-radius:50%;margin-bottom:.9rem;border:2px solid rgba(255,107,53,.5);box-shadow:0 0 18px rgba(255,107,53,.18);transition:.4s;object-fit:cover;}
.team-card:hover img{box-shadow:0 0 28px rgba(255,107,53,.4);transform:scale(1.08);}
.team-card h3{font-family:'Barlow Condensed',sans-serif;font-size:.92rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:.35rem;color:var(--amber);}
.team-card p{font-size:.78rem;color:rgba(255,255,255,.52);line-height:1.5;}

/* SCHEDULE */
.schedule-grid{display:flex;flex-direction:column;gap:.9rem;}
.match-card{background:var(--glass);backdrop-filter:blur(14px);border:1px solid rgba(255,107,53,.18);border-radius:14px;padding:1.05rem 1.5rem;display:grid;grid-template-columns:105px 1fr auto;align-items:center;gap:1.4rem;transition:all .3s ease;position:relative;overflow:hidden;}
.match-card::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:linear-gradient(180deg,var(--orange),var(--amber));border-radius:3px 0 0 3px;}
.match-card:hover{transform:translateX(7px);background:rgba(255,255,255,.09);border-color:rgba(255,107,53,.38);box-shadow:0 5px 22px rgba(255,107,53,.1);}
.match-date-block{text-align:center;}
.match-date-block .day,.match-date-block .month{font-family:'Barlow Condensed',sans-serif;font-size:.6rem;text-transform:uppercase;letter-spacing:2.5px;color:var(--amber);opacity:.8;}
.match-date-block .date{font-family:'Bebas Neue',sans-serif;font-size:1.9rem;color:#fff;line-height:1.1;}
.match-teams{display:flex;align-items:center;gap:.75rem;flex-wrap:wrap;}
.team-name{font-size:.97rem;font-weight:700;color:#fff;}
.team-abbr{display:inline-block;background:linear-gradient(45deg,var(--orange),var(--amber));color:#000;font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:.7rem;padding:.17rem .52rem;border-radius:5px;}
.vs-badge{font-family:'Barlow Condensed',sans-serif;font-size:.62rem;font-weight:700;color:rgba(255,255,255,.28);letter-spacing:2px;}
.match-meta{text-align:right;min-width:155px;}
.match-time{font-family:'Barlow Condensed',sans-serif;font-size:1rem;font-weight:700;color:var(--amber);}
.match-venue{font-size:.73rem;color:rgba(255,255,255,.43);margin-top:.22rem;line-height:1.4;}
.match-number{font-family:'Barlow Condensed',sans-serif;font-size:.6rem;text-transform:uppercase;letter-spacing:1.5px;color:rgba(255,107,53,.58);margin-top:.32rem;}
.double-header-label{display:inline-block;background:rgba(255,179,71,.1);color:var(--amber);font-family:'Barlow Condensed',sans-serif;font-size:.58rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;padding:.1rem .5rem;border-radius:20px;border:1px solid rgba(255,179,71,.28);margin-top:.28rem;}
.schedule-note{text-align:center;font-size:.78rem;color:rgba(255,255,255,.32);margin-top:2rem;}
.date-group-label{font-family:'Barlow Condensed',sans-serif;font-size:.65rem;text-transform:uppercase;letter-spacing:3px;color:rgba(255,107,53,.52);padding:.28rem 0;border-bottom:1px solid rgba(255,107,53,.1);margin-bottom:-.05rem;}

/* STATS */
.stats-intro{text-align:center;font-family:'Barlow Condensed',sans-serif;font-size:.88rem;letter-spacing:1px;color:rgba(255,255,255,.45);margin-top:-1.5rem;margin-bottom:3rem;}
.champion-banner{background:linear-gradient(135deg,rgba(255,107,53,.14),rgba(255,179,71,.07));border:1px solid rgba(255,107,53,.38);border-radius:20px;padding:2rem 2.5rem;display:flex;align-items:center;gap:2rem;margin-bottom:3rem;position:relative;overflow:hidden;}
.champion-banner::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--orange),var(--amber),var(--orange));}
.champion-banner::after{content:'🏆';position:absolute;right:2rem;font-size:5rem;opacity:.1;}
.champion-badge{background:linear-gradient(45deg,var(--orange),var(--amber));color:#000;font-family:'Barlow Condensed',sans-serif;font-size:.65rem;font-weight:800;letter-spacing:2.5px;text-transform:uppercase;padding:.28rem .9rem;border-radius:20px;display:inline-block;margin-bottom:.55rem;}
.champion-banner h3{font-family:'Bebas Neue',sans-serif;font-size:1.9rem;letter-spacing:2px;color:#fff;margin-bottom:.28rem;}
.champion-banner p{font-size:.86rem;color:rgba(255,255,255,.52);line-height:1.6;}
.stats-columns{display:grid;grid-template-columns:1fr 1fr;gap:2.5rem;margin-bottom:3rem;}
.stats-table-block h3{font-family:'Barlow Condensed',sans-serif;font-size:.98rem;font-weight:700;letter-spacing:1px;color:var(--amber);margin-bottom:1.1rem;display:flex;align-items:center;gap:.6rem;}
.cap-icon{display:inline-block;font-family:'Barlow Condensed',sans-serif;font-size:.7rem;font-weight:800;padding:.18rem .6rem;border-radius:6px;letter-spacing:1px;}
.orange-cap{background:linear-gradient(45deg,var(--orange),var(--amber));color:#000;}
.purple-cap{background:linear-gradient(45deg,#7b2d8b,#c45fd6);color:#fff;}
.player-row{display:flex;align-items:center;gap:.9rem;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.06);border-radius:12px;padding:.82rem 1.05rem;margin-bottom:.6rem;transition:.3s;}
.player-row:hover{background:rgba(255,255,255,.08);border-color:rgba(255,107,53,.22);transform:translateX(5px);}
.player-rank{font-family:'Bebas Neue',sans-serif;font-size:1.1rem;color:rgba(255,179,71,.35);width:22px;text-align:center;flex-shrink:0;}
.player-rank.gold{color:var(--amber);}
.player-info{flex:1;}
.player-name{font-size:.9rem;font-weight:700;color:#fff;}
.player-team{font-size:.7rem;color:rgba(255,255,255,.38);margin-top:.1rem;}
.player-stat{text-align:right;}
.stat-value{font-family:'Bebas Neue',sans-serif;font-size:1.25rem;letter-spacing:1px;color:var(--orange);}
.stat-label{font-family:'Barlow Condensed',sans-serif;font-size:.58rem;text-transform:uppercase;letter-spacing:1.5px;color:rgba(255,255,255,.28);}
.stat-detail{font-size:.67rem;color:rgba(255,255,255,.33);margin-top:.06rem;}
.milestones{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1rem;margin-top:1rem;}
.milestone-card{background:var(--glass);border:1px solid var(--border);border-radius:14px;padding:1.2rem 1.3rem;transition:.3s;position:relative;overflow:hidden;}
.milestone-card::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--orange),var(--amber));transform:scaleX(0);transition:.35s;transform-origin:left;}
.milestone-card:hover::after{transform:scaleX(1);}
.milestone-card:hover{background:rgba(255,255,255,.09);border-color:rgba(255,107,53,.28);transform:translateY(-5px);box-shadow:0 10px 30px rgba(0,0,0,.5);}
.milestone-label{font-family:'Barlow Condensed',sans-serif;font-size:.58rem;text-transform:uppercase;letter-spacing:2px;color:rgba(255,107,53,.62);margin-bottom:.42rem;}
.milestone-value{font-family:'Barlow Condensed',sans-serif;font-size:1.12rem;font-weight:700;color:#fff;margin-bottom:.18rem;}
.milestone-desc{font-size:.73rem;color:rgba(255,255,255,.4);line-height:1.55;}
.section-sub-title{font-family:'Barlow Condensed',sans-serif;font-size:.82rem;color:var(--amber);margin:2.5rem 0 1.1rem;font-weight:700;text-transform:uppercase;letter-spacing:3px;}

/* RESULTS */
.results-grid{display:flex;flex-direction:column;gap:.9rem;}
.result-card{background:var(--glass);border:1px solid var(--border);border-radius:14px;padding:.95rem 1.4rem;display:grid;grid-template-columns:85px 1fr auto;align-items:center;gap:1.1rem;transition:.3s;position:relative;overflow:hidden;}
.result-card::before{content:'';position:absolute;left:0;top:0;bottom:0;width:4px;border-radius:4px 0 0 4px;}
.result-card.win-left::before{background:linear-gradient(180deg,#22c55e,#16a34a);}
.result-card.win-right::before{background:linear-gradient(180deg,var(--orange),var(--amber));}
.result-card:hover{background:rgba(255,255,255,.08);transform:translateX(6px);}
.result-match-no .match-num{font-family:'Barlow Condensed',sans-serif;font-size:.6rem;text-transform:uppercase;letter-spacing:2px;color:rgba(255,107,53,.62);}
.result-match-no .match-date-sm{font-size:.73rem;color:rgba(255,255,255,.36);margin-top:.16rem;}
.result-teams{display:flex;flex-direction:column;gap:.28rem;}
.result-divider{height:1px;background:rgba(255,255,255,.06);margin:.06rem 0;}
.result-team-row{display:flex;align-items:center;gap:.55rem;}
.result-team-row .abbr{font-family:'Barlow Condensed',sans-serif;font-size:.67rem;font-weight:800;padding:.13rem .42rem;border-radius:5px;background:rgba(255,255,255,.08);color:var(--amber);min-width:38px;text-align:center;}
.result-team-row .team-nm{font-size:.84rem;font-weight:600;color:#fff;}
.result-team-row .score{margin-left:auto;font-family:'Barlow Condensed',sans-serif;font-size:.98rem;font-weight:700;color:#fff;}
.result-team-row.winner .team-nm,.result-team-row.winner .score{color:#4ade80;}
.result-team-row.loser .team-nm,.result-team-row.loser .score{opacity:.44;}
.result-margin{text-align:right;min-width:125px;}
.win-by{font-family:'Barlow Condensed',sans-serif;font-size:.82rem;font-weight:700;color:var(--amber);}
.result-venue{font-size:.63rem;color:rgba(255,255,255,.3);margin-top:.2rem;}

/* POINTS TABLE */
.points-table-wrap{overflow-x:auto;border-radius:16px;border:1px solid var(--border);}
.points-table{width:100%;border-collapse:collapse;font-size:.86rem;}
.points-table thead tr{background:rgba(255,107,53,.12);}
.points-table th{padding:.88rem 1rem;text-align:center;font-family:'Barlow Condensed',sans-serif;font-size:.62rem;text-transform:uppercase;letter-spacing:1.5px;color:var(--amber);font-weight:700;white-space:nowrap;}
.points-table th:first-child{text-align:left;padding-left:1.2rem;}
.points-table td{padding:.75rem 1rem;text-align:center;border-bottom:1px solid rgba(255,255,255,.05);color:rgba(255,255,255,.8);white-space:nowrap;}
.points-table td:first-child{text-align:left;padding-left:1rem;}
.points-table tbody tr{transition:.22s;}
.points-table tbody tr:hover{background:rgba(255,107,53,.05);}
.points-table tbody tr.playoff-zone{border-left:3px solid rgba(34,197,94,.55);}
.points-table tbody tr.eliminated{opacity:.46;}
.pos-num{display:inline-flex;align-items:center;justify-content:center;width:24px;height:24px;border-radius:50%;font-family:'Barlow Condensed',sans-serif;font-size:.76rem;font-weight:800;}
.pos-num.gold{background:linear-gradient(135deg,var(--amber),var(--orange));color:#000;}
.pos-num.silver{background:rgba(255,255,255,.18);color:#fff;}
.pos-num.bronze{background:rgba(205,127,50,.32);color:var(--amber);}
.pos-num.q{background:rgba(34,197,94,.18);color:#4ade80;}
.pos-num.out{background:rgba(255,255,255,.07);color:rgba(255,255,255,.36);}
.team-cell{display:flex;align-items:center;gap:.55rem;}
.team-short{font-weight:700;color:#fff;}
.team-full-name{font-size:.7rem;color:rgba(255,255,255,.36);}
.nrr-pos{color:#4ade80;font-weight:600;}
.nrr-neg{color:#f87171;font-weight:600;}
.pts-val{font-family:'Bebas Neue',sans-serif;font-size:1.1rem;letter-spacing:1px;color:var(--orange);}
.playoff-tag{font-family:'Barlow Condensed',sans-serif;font-size:.52rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;padding:.08rem .4rem;border-radius:4px;margin-left:.35rem;background:rgba(34,197,94,.12);color:#4ade80;border:1px solid rgba(34,197,94,.22);vertical-align:middle;}
.table-legend{display:flex;gap:1.4rem;margin-top:.9rem;font-size:.68rem;font-family:'Barlow Condensed',sans-serif;color:rgba(255,255,255,.36);flex-wrap:wrap;letter-spacing:.5px;}
.legend-dot{display:inline-block;width:10px;height:3px;border-radius:2px;margin-right:.32rem;vertical-align:middle;}

/* PROFILES */
.profiles-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(285px,1fr));gap:1.4rem;}
.profile-card{background:var(--glass);border:1px solid var(--border);border-radius:18px;padding:1.45rem;transition:all .35s cubic-bezier(.22,.68,0,1.2);position:relative;overflow:hidden;}
.profile-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--orange),var(--amber));transform:scaleX(0);transition:.35s;transform-origin:left;}
.profile-card::after{content:'';position:absolute;top:0;right:0;width:70px;height:70px;border-radius:0 18px 0 70px;background:linear-gradient(135deg,rgba(255,107,53,.08),transparent);}
.profile-card:hover::before{transform:scaleX(1);}
.profile-card:hover{transform:translateY(-8px);background:rgba(255,255,255,.09);border-color:rgba(255,107,53,.28);box-shadow:0 16px 40px rgba(0,0,0,.6);}
.profile-header{display:flex;align-items:center;gap:.95rem;margin-bottom:.95rem;}
.profile-avatar{width:50px;height:50px;border-radius:50%;background:linear-gradient(135deg,var(--orange),var(--amber));display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:1px;color:#000;flex-shrink:0;border:2px solid rgba(255,107,53,.38);box-shadow:0 0 14px rgba(255,107,53,.18);}
.p-name{font-size:.98rem;font-weight:700;color:#fff;}
.p-role{font-family:'Barlow Condensed',sans-serif;font-size:.7rem;color:rgba(255,179,71,.8);margin-top:.08rem;}
.p-team{font-size:.65rem;color:rgba(255,255,255,.36);}
.profile-bio{font-size:.76rem;color:rgba(255,255,255,.48);line-height:1.65;margin-bottom:.95rem;border-top:1px solid rgba(255,255,255,.07);padding-top:.75rem;}
.profile-stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:.45rem;}
.profile-stat-box{background:rgba(255,255,255,.05);border-radius:8px;padding:.5rem .38rem;text-align:center;border:1px solid rgba(255,255,255,.05);}
.ps-val{font-family:'Bebas Neue',sans-serif;font-size:1.05rem;letter-spacing:1px;color:var(--orange);}
.ps-lbl{font-family:'Barlow Condensed',sans-serif;font-size:.54rem;text-transform:uppercase;letter-spacing:1px;color:rgba(255,255,255,.3);margin-top:.08rem;}

/* AWARDS */
.awards-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(225px,1fr));gap:1.1rem;}
.award-card{background:var(--glass);border:1px solid var(--border);border-radius:14px;padding:1.25rem 1.4rem;transition:.3s;position:relative;overflow:hidden;}
.award-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--orange),var(--amber));border-radius:14px 14px 0 0;}
.award-card:hover{background:rgba(255,255,255,.09);border-color:rgba(255,107,53,.28);transform:translateY(-6px);box-shadow:0 12px 35px rgba(0,0,0,.5);}
.award-icon{font-size:1.75rem;margin-bottom:.55rem;}
.award-title{font-family:'Barlow Condensed',sans-serif;font-size:.6rem;text-transform:uppercase;letter-spacing:2px;color:rgba(255,107,53,.62);margin-bottom:.28rem;}
.award-winner{font-size:1.02rem;font-weight:800;color:#fff;margin-bottom:.13rem;}
.award-team{font-family:'Barlow Condensed',sans-serif;font-size:.72rem;color:var(--amber);margin-bottom:.38rem;}
.award-detail{font-size:.72rem;color:rgba(255,255,255,.4);line-height:1.55;}

/* POLL */
.poll-wrap{max-width:660px;margin:0 auto;}
.poll-question{text-align:center;font-family:'Bebas Neue',sans-serif;font-size:1.75rem;letter-spacing:3px;color:#fff;margin-bottom:.38rem;}
.poll-sub{text-align:center;font-family:'Barlow Condensed',sans-serif;font-size:.75rem;letter-spacing:1px;color:rgba(255,255,255,.32);margin-bottom:1.9rem;}
.poll-options{display:flex;flex-direction:column;gap:.8rem;}
.poll-option{position:relative;background:var(--glass);border:1px solid var(--border);border-radius:12px;padding:.88rem 1.15rem;cursor:pointer;transition:.3s;overflow:hidden;user-select:none;}
.poll-option:hover{border-color:rgba(255,107,53,.4);background:rgba(255,255,255,.08);}
.poll-option.selected{border-color:var(--orange);background:rgba(255,107,53,.1);}
.poll-bar{position:absolute;left:0;top:0;bottom:0;background:linear-gradient(90deg,rgba(255,107,53,.17),rgba(255,179,71,.06));border-radius:12px;transition:width .7s ease;pointer-events:none;}
.poll-option-inner{position:relative;display:flex;align-items:center;gap:.75rem;}
.poll-team-abbr{background:linear-gradient(45deg,var(--orange),var(--amber));color:#000;font-family:'Barlow Condensed',sans-serif;font-size:.7rem;font-weight:800;padding:.18rem .48rem;border-radius:6px;min-width:42px;text-align:center;flex-shrink:0;}
.poll-team-name{font-size:.88rem;font-weight:600;color:#fff;flex:1;}
.poll-pct{font-family:'Bebas Neue',sans-serif;font-size:1.2rem;letter-spacing:1px;color:var(--amber);min-width:42px;text-align:right;}
.poll-count{font-size:.6rem;color:rgba(255,255,255,.28);margin-top:.08rem;text-align:right;}
.poll-voted-note{text-align:center;margin-top:1.4rem;font-size:.78rem;font-family:'Barlow Condensed',sans-serif;letter-spacing:.5px;color:rgba(255,255,255,.32);}
.poll-voted-note span{color:var(--amber);font-weight:700;}

/* FOOTER */
footer{text-align:center;padding:2.5rem 2rem;border-top:1px solid rgba(255,107,53,.14);background:rgba(0,0,0,.3);}
.footer-logo{font-family:'Bebas Neue',sans-serif;font-size:1.55rem;letter-spacing:4px;background:linear-gradient(90deg,var(--orange),var(--amber));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:.45rem;}
footer p{font-size:.75rem;color:rgba(255,255,255,.28);letter-spacing:.5px;}

